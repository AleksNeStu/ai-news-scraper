# =====================================================
# AI News Scraper — Environment variables
# Copy to .env and fill in real values.
# =====================================================

# ---------- General ----------
APP_ENV=development
LOG_LEVEL=INFO

# ---------- Backend (apps/api) ----------
API_HOST=0.0.0.0
API_PORT=8082
API_INTERNAL_URL=http://api:8082

# ---------- Database (Postgres) ----------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_news
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/ai_news

# ---------- Vector DB (ChromaDB) ----------
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./chroma_db

# ---------- Cache (Redis) ----------
REDIS_URL=redis://localhost:6379/0

# ---------- AI providers ----------
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=
EMBEDDING_DIMENSIONS=1536

# ---------- Auth ----------
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=1440

# ---------- RSS ----------
RSS_POLL_INTERVAL_SEC=900
RSS_MAX_ITEMS_PER_POLL=50
RSS_USER_AGENT=ai-news-scraper/0.1

# ---------- Frontend (apps/web) ----------
NEXT_PUBLIC_API_URL=http://localhost:8082
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="AI News Search"
